<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#E0E0E0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Task"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="20dp"/>

    <!-- Title input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="What do you need to do?"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="#5E35B1"
        app:hintTextColor="#5E35B1"
        android:layout_marginBottom="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="2"
            android:textSize="15sp"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Priority label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Priority"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#616161"
        android:layout_marginBottom="8dp"/>

    <!-- Priority chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgPriority"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="20dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipHigh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128308; High"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#FFEBEE"
            android:textColor="#C62828"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128992; Medium"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#FFF3E0"
            android:textColor="#E65100"
            app:checkedIconVisible="true"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipLow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128994; Low"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E8F5E9"
            android:textColor="#2E7D32"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Category label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#616161"
        android:layout_marginBottom="8dp"/>

    <!-- Category chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="28dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWork"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128188; Work"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPersonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#129309; Personal"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipHealth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#128170; Health"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipOther"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#127775; Other"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Add button -->
    <Button
        android:id="@+id/btnAddTask"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Add Task"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#5E35B1"
        android:stateListAnimator="@null"
        style="@style/Widget.MaterialComponents.Button"/>

</LinearLayout>
